# Copy to .env and adjust. Never commit .env with real secrets.

# Async SQLAlchemy (must use postgresql+asyncpg)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/aitutor

# OpenAI-compatible API (set key for cloud; Ollama may use a dummy key)
OPENAI_API_KEY=

# LLM
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT_SECONDS=120
LLM_MAX_RETRIES=3

# Embeddings / RAG
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
RAG_TOP_K=5
RAG_CHUNK_MAX_TOKENS=512
RAG_CHUNK_OVERLAP_TOKENS=64

# Conversation context
CHAT_CONTEXT_MAX_MESSAGES=20

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
